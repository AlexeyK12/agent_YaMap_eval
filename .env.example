# Copy this file to .env and paste your real key there.
# Never commit .env with real credentials.

ROUTERAI_API_KEY=
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
AGENT_MODEL=deepseek/deepseek-v4-pro

# Use serper for the search-enabled agent required by the project.
SEARCH_PROVIDER=serper
SERPER_API_KEY=

# Optional alternative search provider.
# TAVILY_API_KEY=
