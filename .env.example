# Скопируйте этот файл в .env и вставьте реальные ключи туда.
# Никогда не коммитьте .env с настоящими ключами.

ROUTERAI_API_KEY=
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
AGENT_MODEL=deepseek/deepseek-v4-pro

# Serper используется для агента с внешним поиском.
SEARCH_PROVIDER=serper
SERPER_API_KEY=

# Опциональная альтернатива Serper.
# TAVILY_API_KEY=
